<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.8.xsd">

  <changeSet author="havonte" id="20260303-00">
    <sql>
      CREATE SCHEMA IF NOT EXISTS quicksearch
    </sql>
  </changeSet>

  <changeSet author="havonte" id="20260303-01">
    <createTable schemaName="quicksearch" tableName="qs_pokemon_series">
      <column autoIncrement="true" name="id" type="VARCHAR(255)">
        <constraints nullable="false" primaryKey="true"/>
      </column>
      <column name="name_de" type="VARCHAR(255)"/>
      <column name="name_en" type="VARCHAR(255)"/>
      <column name="name_fr" type="VARCHAR(255)"/>
    </createTable>
  </changeSet>

  <changeSet author="havonte" id="20260303-02">
    <createTable schemaName="quicksearch" tableName="qs_pokemon_sets">
      <column autoIncrement="true" name="id" type="VARCHAR(255)">
        <constraints nullable="false" primaryKey="true"/>
      </column>
      <column name="abbreviation" type="VARCHAR(255)"/>
      <column name="cm_product_id" type="VARCHAR(255)"/>
      <column name="code" type="VARCHAR(255)"/>
      <column name="name_de" type="VARCHAR(255)"/>
      <column name="name_en" type="VARCHAR(255)"/>
      <column name="name_fr" type="VARCHAR(255)"/>
      <column name="official" type="INTEGER"/>
      <column name="tcgp_id" type="VARCHAR(255)"/>
      <column name="total" type="INTEGER"/>
      <column name="series_id" type="VARCHAR(255)"/>
    </createTable>
  </changeSet>

  <changeSet author="havonte" id="20260303-03">
    <createTable schemaName="quicksearch" tableName="qs_pokemon_cards">
      <column autoIncrement="true" name="id" type="VARCHAR(255)">
        <constraints nullable="false" primaryKey="true"/>
      </column>
      <column name="cm_page_id" type="VARCHAR(255)"/>
      <column name="cm_product_id" type="VARCHAR(255)"/>
      <column name="code" type="VARCHAR(255)"/>
      <column name="name_de" type="VARCHAR(255)"/>
      <column name="name_en" type="VARCHAR(255)"/>
      <column name="name_fr" type="VARCHAR(255)"/>
      <column name="set_id" type="VARCHAR(255)"/>
      <column name="tcgp_id" type="VARCHAR(255)"/>
    </createTable>
  </changeSet>

  <changeSet author="havonte" id="20260303-04">
    <createIndex schemaName="quicksearch" tableName="qs_pokemon_sets" indexName="idx_qs_sets_code">
      <column name="code"/>
    </createIndex>
    <createIndex schemaName="quicksearch" tableName="qs_pokemon_sets" indexName="idx_qs_sets_series_id">
      <column name="series_id"/>
    </createIndex>
  </changeSet>

  <changeSet author="havonte" id="20260303-05">
    <createIndex schemaName="quicksearch" tableName="qs_pokemon_cards" indexName="idx_qs_cards_code">
      <column name="code"/>
    </createIndex>
    <createIndex schemaName="quicksearch" tableName="qs_pokemon_cards" indexName="idx_qs_cards_set_id">
      <column name="set_id"/>
    </createIndex>
  </changeSet>

</databaseChangeLog>
