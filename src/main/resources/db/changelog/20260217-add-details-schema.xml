<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.8.xsd">

  <changeSet author="opencode" id="20260217-01">
    <addColumn schemaName="watcher" tableName="products">
      <column name="details_url" type="VARCHAR(512)"/>
    </addColumn>
  </changeSet>

  <changeSet author="opencode" id="20260217-02">
    <createTable schemaName="watcher" tableName="sell_offers">
      <column autoIncrement="true" name="id" type="BIGINT">
        <constraints nullable="false" primaryKey="true"/>
      </column>
      <column name="product_id" type="BIGINT">
        <constraints nullable="false"/>
      </column>
      <column name="seller_name" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="seller_location" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="product_language" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="special" type="VARCHAR(255)">
        <constraints nullable="false" defaultValue=""/>
      </column>
      <column name="condition" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="amount" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="price" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>

  <changeSet author="opencode" id="20260217-03">
    <addForeignKeyConstraint baseColumnNames="product_id"
      baseTableName="sell_offers"
      baseTableSchemaName="watcher"
      constraintName="fk_sell_offer_product"
      onDelete="CASCADE"
      referencedColumnNames="id"
      referencedTableName="products"
      referencedTableSchemaName="watcher"/>
  </changeSet>

</databaseChangeLog>
