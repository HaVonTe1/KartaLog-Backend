<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.8.xsd">


  <changeSet author="dirk" id="20260207-00">
    <sql>CREATE SCHEMA IF NOT EXISTS watcher</sql>
  </changeSet>


  <changeSet author="dirk" id="20260207-01">
    <createTable schemaName="watcher" tableName="products">
      <column autoIncrement="true" name="id" type="BIGINT">
        <constraints nullable="false" primaryKey="true"/>
      </column>
      <column name="external_id" type="BIGINT">
        <constraints nullable="false" unique="true"/>
      </column>
      <column name="set_name" type="VARCHAR(255)"/>
      <column name="rarity" type="VARCHAR(255)"/>
      <column name="code_info" type="VARCHAR(255)"/>
      <column name="code_info_valid" type="BOOLEAN"/>
      <column name="genre" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="type" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="cm_id" type="VARCHAR(255)"/>
      <column name="img_link" type="VARCHAR(255)"/>
      <column name="price" type="VARCHAR(255)"/>
      <column name="price_trend" type="VARCHAR(255)"/>
      <column name="price_trend_valid" type="BOOLEAN"/>
      <column defaultValueComputed="CURRENT_TIMESTAMP" name="created_at" type="TIMESTAMP">
        <constraints nullable="false"/>
      </column>
      <column defaultValueComputed="CURRENT_TIMESTAMP" name="updated_at" type="TIMESTAMP">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>

  <changeSet author="dirk" id="20260207-04">
    <createIndex schemaName="watcher" tableName="products" indexName="idx_products_set_name">
      <column name="set_name"/>
    </createIndex>
    <createIndex schemaName="watcher" tableName="products" indexName="idx_products_rarity">
      <column name="rarity"/>
    </createIndex>
    <createIndex schemaName="watcher" tableName="products" indexName="idx_products_genre">
      <column name="genre"/>
    </createIndex>
    <createIndex schemaName="watcher" tableName="products" indexName="idx_products_type">
      <column name="type"/>
    </createIndex>
  </changeSet>

  <changeSet author="dirk" id="20260207-02">

    <createTable schemaName="watcher" tableName="product_name_translations">
      <column autoIncrement="true" name="id" type="BIGINT">
        <constraints nullable="false" primaryKey="true"/>
      </column>
      <column name="product_id" type="BIGINT">
        <constraints nullable="false"/>
      </column>
      <column name="language_code" type="VARCHAR(5)">
        <constraints nullable="false"/>
      </column>
      <column name="name" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
    </createTable>
      <addForeignKeyConstraint baseColumnNames="product_id"
        baseTableName="product_name_translations"
        baseTableSchemaName="watcher"
        constraintName="fk_name_translation_product"
        onDelete="CASCADE"
        referencedColumnNames="id"
        referencedTableName="products"
        referencedTableSchemaName="watcher"/>
  </changeSet>

  <changeSet author="dirk" id="20260207-03">


    <createTable schemaName="watcher" tableName="search_results">
      <column autoIncrement="true" name="id" type="BIGINT">
        <constraints nullable="false" primaryKey="true"/>
      </column>
      <column name="query" type="VARCHAR(255)">
        <constraints nullable="false" unique="true"/>
      </column>
      <column name="cached_at" type="TIMESTAMP">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <createTable schemaName="watcher" tableName="search_result_products">
      <column name="search_result_id" type="BIGINT">
        <constraints nullable="false"/>
      </column>
      <column name="product_id" type="BIGINT">
        <constraints nullable="false"/>
      </column>
    </createTable>
      <addForeignKeyConstraint baseColumnNames="search_result_id"
        baseTableName="search_result_products"
        baseTableSchemaName="watcher"
        constraintName="fk_search_result_product"
        onDelete="CASCADE"
        referencedColumnNames="id"
        referencedTableName="search_results"
        referencedTableSchemaName="watcher"/>

      <addForeignKeyConstraint baseColumnNames="product_id"
        baseTableName="search_result_products"
        baseTableSchemaName="watcher"
        constraintName="fk_search_result_product_product"
        onDelete="CASCADE"
        referencedColumnNames="id"
        referencedTableName="products"
        referencedTableSchemaName="watcher"/>
  </changeSet>


</databaseChangeLog>
