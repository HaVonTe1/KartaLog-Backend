<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.10.xsd">

    <!-- Languages table -->
    <changeSet id="1-create-languages-table" author="havonte">
        <createTable tableName="languages" schemaName="watcher">
            <column name="code" type="VARCHAR(5)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>

    <!-- Products table -->
    <changeSet id="2-create-products-table" author="havonte">
        <createTable tableName="products" schemaName="watcher">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="external_id" type="BIGINT">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="set_name" type="VARCHAR(255)"/>
            <column name="rarity" type="VARCHAR(255)"/>
            <column name="image_url" type="VARCHAR(512)"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <!-- Localized strings table -->
    <changeSet id="3-create-localized-strings-table" author="havonte">
        <createTable tableName="localized_strings" schemaName="watcher">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="product_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_localized_product" references="watcher.products(id)"/>
            </column>
            <column name="language_code" type="VARCHAR(5)">
                <constraints nullable="false" foreignKeyName="fk_localized_language" references="watcher.languages(code)"/>
            </column>
            <column name="type" type="VARCHAR(30)"/>
            <column name="value" type="CLOB"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
